<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     xmlns:tools="http://schemas.android.com/tools"
     android:layout_height="40dp"
     android:layout_width="match_parent"
     android:paddingEnd="8dp"
     android:gravity="center_vertical"
     android:background="?attr/selectableItemBackground"
     android:clickable="true"
     android:orientation="horizontal"
     android:focusable="true">

    <View
         android:layout_height="match_parent"
         android:layout_width="0dp"
         android:id="@+id/tv_indent" />

    <CheckBox
         android:layout_height="20dp"
         android:layout_width="20dp"
         android:visibility="gone"
         android:clickable="false"
         android:scaleX="0.8"
         android:scaleY="0.8"
         android:textSize="12sp"
         android:id="@+id/tv_checkbox" />

    <ViewFlipper
         android:layout_height="16dp"
         android:layout_width="16dp"
         android:id="@+id/tv_arrow_switcher">

        <ImageView
             android:layout_height="16dp"
             android:layout_width="16dp"
             android:src="@drawable/ic_arrow_right"
             android:scaleType="centerInside"
             android:contentDescription="@string/cd_expand_arrow"
             android:id="@+id/tv_arrow" />

        <ProgressBar
             android:layout_height="14dp"
             android:layout_width="14dp"
             android:indeterminate="true"
             android:id="@+id/tv_arrow_loading" />

    </ViewFlipper>

    <ImageView
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:src="@drawable/ic_filetree_folder"
         android:scaleType="centerInside"
         android:layout_marginEnd="4dp"
         android:contentDescription="@string/cd_node_icon"
         android:layout_marginStart="4dp"
         android:id="@+id/tv_icon" />

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="0dp"
         android:textDirection="locale"
         android:ellipsize="end"
         android:textSize="13sp"
         android:maxLines="1"
         android:layout_weight="2"
         android:id="@+id/tv_name"
         android:text="@string/app_name" />

    <ImageView
         android:layout_height="12dp"
         android:layout_width="12dp"
         android:visibility="gone"
         android:src="@drawable/ic_badge_git_conflict"
         android:scaleType="centerInside"
         android:contentDescription="@string/cd_badge_icon"
         android:layout_marginStart="4dp"
         android:id="@+id/tv_badge_icon" />

    <ImageView
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:src="@drawable/icon_attach_file_round"
         android:scaleType="centerInside"
         android:contentDescription="@string/cd_badge_icon"
         android:layout_marginLeft="4dp"
         android:layout_marginRight="4dp"
         android:layout_marginStart="4dp"
         android:id="@+id/filecreator" />

    <ImageView
         android:layout_height="18dp"
         android:layout_width="18dp"
         android:src="@drawable/icon_create_new_folder_round"
         android:scaleType="centerInside"
         android:contentDescription="@string/cd_badge_icon"
         android:layout_marginLeft="2dp"
         android:layout_marginRight="4dp"
         android:layout_marginStart="4dp"
         android:id="@+id/foldercreator" />

    <TextView
         android:layout_height="wrap_content"
         android:layout_width="wrap_content"
         android:visibility="gone"
         android:textSize="10sp"
         android:layout_marginStart="4dp"
         android:id="@+id/tv_badge" />

</LinearLayout>