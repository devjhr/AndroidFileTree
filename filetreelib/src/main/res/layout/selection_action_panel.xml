<?xml version="1.0" encoding="utf-8"?>

<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Row 1 : count label + close button ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        >

        <TextView
            android:id="@+id/txt_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 items selected"
            android:textColor="?colorOnSurface"
            android:textSize="13sp"
            android:textStyle="bold"
            />

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close_selection"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_close"
            android:tint="?colorOnSurface"
            />

    </LinearLayout>

    <!-- ── Thin divider ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.10"
        android:id="@+id/divview"
        android:background="?colorOnSurface"
        />

    <!-- ── Row 2 : action buttons ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="4dp"
        >

        <!-- Copy -->
        <ImageView
            android:id="@+id/btn_copy"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_copy"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_copy"
            android:tint="?colorOnSurface"
            />

        <!-- Cut -->
        <ImageView
            android:id="@+id/btn_cut"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_cut"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_cut"
            android:tint="?colorOnSurface"
            />

        <!-- Paste (dimmed when clipboard is empty) -->
        <ImageView
            android:id="@+id/btn_paste"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_paste"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_paste"
            android:tint="?colorOnSurface"
            />

        <!-- Rename — visible only when exactly 1 node selected -->
        <ImageView
            android:id="@+id/btn_rename"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_rename"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_rename"
            android:tint="?colorOnSurface"
            android:visibility="gone"
            />

        <!-- Select All -->
        <ImageView
            android:id="@+id/btn_selectall"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_select_all"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/filetree_outline_select_all"
            android:tint="?colorOnSurface"
            />

        <!-- Delete -->
        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_delete"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_filetree_delete"
            android:tint="?colorOnSurface"
            />

        <!-- More ⋮ -->
        <ImageView
            android:id="@+id/selectionmore"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_more_options"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/filetree_more_vert"
            android:tint="?colorOnSurface"
            />

    </LinearLayout>

</merge>
